---
/**
 * Clean Language Toggle (EN | FR)
 *
 * Uses Google Translate but with custom styled buttons
 * instead of the ugly default dropdown.
 */
---

<!-- Clean Language Toggle -->
<div class="lang-toggle notranslate" translate="no">
  <button class="lang-btn active notranslate" data-lang="en" title="English" translate="no">EN</button>
  <span class="lang-divider">|</span>
  <button class="lang-btn notranslate" data-lang="fr" title="Français" translate="no">FR</button>
</div>

<!-- Hidden Google Translate Element -->
<div id="google_translate_element" style="display: none;"></div>

<script is:inline>
  let translateSelect = null;

  function googleTranslateElementInit() {
    new google.translate.TranslateElement({
      pageLanguage: 'en',
      includedLanguages: 'en,fr',
      autoDisplay: false
    }, 'google_translate_element');

    // Poll every 30ms until the select is ready, then cache it
    const checkReady = setInterval(() => {
      const sel = document.querySelector('.goog-te-combo');
      if (sel) {
        clearInterval(checkReady);
        translateSelect = sel;
      }
    }, 30);
  }

  function doTranslate(lang) {
    // Refresh reference in case it was lost
    if (!translateSelect) translateSelect = document.querySelector('.goog-te-combo');
    if (!translateSelect) return;
    translateSelect.value = lang;
    translateSelect.dispatchEvent(new Event('change'));
  }

  document.addEventListener('DOMContentLoaded', function() {
    const langBtns = document.querySelectorAll('.lang-btn');

    langBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const lang = this.getAttribute('data-lang');

        // Immediate visual feedback
        langBtns.forEach(b => { b.classList.remove('active'); b.style.opacity = '0.6'; });
        this.classList.add('active');
        this.style.opacity = '1';

        doTranslate(lang);

        // Restore opacity once translation settles
        setTimeout(() => langBtns.forEach(b => { b.style.opacity = ''; }), 800);
      });
    });

    checkCurrentLanguage();
  });

  // Check current language on page load
  function checkCurrentLanguage() {
    const langCookie = document.cookie.match(/googtrans=\/en\/(\w+)/);
    if (langCookie && langCookie[1] === 'fr') {
      const frBtn = document.querySelector('.lang-btn[data-lang="fr"]');
      const enBtn = document.querySelector('.lang-btn[data-lang="en"]');
      if (frBtn && enBtn) {
        enBtn.classList.remove('active');
        frBtn.classList.add('active');
      }
    }
  }
</script>

<!-- Load Google Translate script with high priority -->
<script is:inline src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" defer></script>

<style>
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: #f8f9fa;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    border: 1px solid #e0e0e0;
    position: relative;
    transition: opacity 0.2s ease;
  }

  .lang-btn {
    background: none;
    border: none;
    padding: 0.25rem 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #999;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .lang-btn:hover {
    color: #f0a500;
  }

  .lang-btn.active {
    background: #111111;
    color: white;
  }

  .lang-btn:active {
    transform: scale(0.95);
  }

  .lang-divider {
    color: #ddd;
    font-size: 0.75rem;
  }

  /* Hide ALL Google Translate UI elements */
  :global(.goog-te-banner-frame),
  :global(.skiptranslate),
  :global(.goog-te-gadget-icon),
  :global(#goog-gt-tt),
  :global(.goog-te-balloon-frame),
  :global(.goog-te-menu-frame),
  :global(.goog-te-menu2),
  :global(#google_translate_element),
  :global(.goog-te-spinner-pos),
  :global(.goog-tooltip),
  :global(.goog-tooltip:hover),
  :global(.goog-text-highlight) {
    display: none !important;
    visibility: hidden !important;
  }

  :global(body) {
    top: 0 !important;
    position: static !important;
  }

  :global(html.translated-ltr),
  :global(html.translated-rtl) {
    margin-top: 0 !important;
  }

  :global(.goog-text-highlight) {
    background: none !important;
    box-shadow: none !important;
  }

  /* Hide the iframe that Google injects */
  :global(iframe.goog-te-banner-frame),
  :global(iframe.skiptranslate) {
    display: none !important;
    height: 0 !important;
    width: 0 !important;
    border: none !important;
  }
</style>
