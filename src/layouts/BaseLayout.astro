---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Quality essentials for everyday life - Imported with care from USA and Canada to Cameroon' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover" />
    <meta name="theme-color" content="#111111" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="format-detection" content="telephone=yes" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/icon-180x180.png" />
    <meta name="apple-mobile-web-app-title" content="AmericanSelect" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style is:inline>
      /* Critical mobile CSS - loaded immediately */
      html {
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }
      body {
        -webkit-tap-highlight-color: transparent;
        touch-action: manipulation;
        /* Reserve space for iPhone home bar */
        padding-bottom: env(safe-area-inset-bottom, 0px);
      }
      /* Prevent horizontal overflow on mobile */
      html, body {
        overflow-x: hidden;
        max-width: 100vw;
      }
      /* Safe area for sticky navbar (notch / Dynamic Island) */
      .navbar {
        padding-top: env(safe-area-inset-top, 0px);
      }
      /* iOS install banner — hidden by default, shown by JS */
      .ios-install-banner {
        display: none;
        position: fixed;
        bottom: 0; left: 0; right: 0;
        z-index: 9999;
        background: #111;
        color: #e0e0e0;
        padding: 14px calc(16px + env(safe-area-inset-right,0px)) calc(14px + env(safe-area-inset-bottom,0px)) calc(16px + env(safe-area-inset-left,0px));
        align-items: center;
        gap: 12px;
        box-shadow: 0 -2px 12px rgba(0,0,0,0.4);
        -webkit-transform: translateZ(0);
        transform: translateZ(0);
        will-change: transform;
        -webkit-user-select: none;
        user-select: none;
      }
      .ios-install-banner.visible { display: flex; }
    </style>
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- WhatsApp floating button - appears on all pages -->
    <WhatsAppFloat />

    <!-- iOS install banner -->
    <div id="ios-install-banner" class="ios-install-banner">
      <img src="/icons/icon-72x72.png" style="width:44px;height:44px;border-radius:10px;flex-shrink:0;" alt="">
      <div style="flex:1;min-width:0;">
        <div style="font-weight:700;font-size:14px;color:#fff;">Install American Select</div>
        <div style="font-size:12px;color:#888;margin-top:2px;">Tap <strong style="color:#d4af37;">Share</strong> then <strong style="color:#d4af37;">Add to Home Screen</strong></div>
      </div>
      <button onclick="document.getElementById('ios-install-banner').classList.remove('visible');localStorage.setItem('pwa-banner-dismissed','1');" style="background:transparent;border:none;color:#888;font-size:22px;cursor:pointer;min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center;flex-shrink:0;touch-action:manipulation;-webkit-tap-highlight-color:transparent;-webkit-appearance:none;appearance:none;-webkit-user-select:none;user-select:none;">✕</button>
    </div>

    <script is:inline>
      // Register service worker
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }

      (function() {
        const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
        const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
        const isStandalone = window.navigator.standalone === true || window.matchMedia('(display-mode: standalone)').matches;
        const dismissed = localStorage.getItem('pwa-banner-dismissed');

        let deferredPrompt = null;

        // Hide the entire footer install section if already running as installed app
        if (isStandalone) {
          const section = document.getElementById('footer-install-section');
          if (section) section.style.display = 'none';
        }

        function showInstallButtons() {
          const navBtn = document.getElementById('nav-install-btn');
          const footerBtn = document.getElementById('footer-install-btn');
          if (navBtn) navBtn.style.display = 'inline-flex';
          if (footerBtn) footerBtn.style.display = 'flex';
        }

        function showIOSBanner() {
          const banner = document.getElementById('ios-install-banner');
          if (banner) banner.classList.add('visible');
        }

        function handleInstallClick() {
          if (deferredPrompt) {
            deferredPrompt.prompt();
            deferredPrompt.userChoice.then(() => { deferredPrompt = null; });
          } else if (isIOS) {
            showIOSBanner();
          }
        }

        function wireButtons() {
          ['nav-install-btn', 'footer-install-btn'].forEach(id => {
            const btn = document.getElementById(id);
            if (btn) btn.addEventListener('click', handleInstallClick);
          });
        }

        // Android/Chrome — capture install prompt
        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;
          if (!isStandalone) showInstallButtons();
        });

        // iOS — show buttons for all iOS browsers, show banner on Safari only
        if (isIOS && !isStandalone) {
          showInstallButtons();
          if (isSafari && !dismissed) showIOSBanner();
        }

        // Wire buttons — handle case where DOMContentLoaded already fired
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', wireButtons);
        } else {
          wireButtons();
        }
      })();
    </script>
  </body>
</html>

