---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/bulk-orders.css';

const web3formsEndpoint = "https://api.web3forms.com/submit";
const web3formsKey = "76ebc4cd-2b2b-42d3-b14a-c27e0191a990";
---

<BaseLayout title="Bulk Orders - Special Pricing for Businesses">
  <section class="bulk-hero">
    <div class="container bulk-hero-content">
      <h1>Bulk Orders</h1>
      <p class="lead">Special Pricing for Businesses and Large Orders</p>
    </div>
  </section>

  <section class="bulk-content section">
    <div class="container">
      <div class="bulk-intro">
        <h2>Why Choose Bulk Orders?</h2>
        <p>
          Whether you're a retailer, distributor, or organization needing large quantities
          of essential goods, we offer competitive bulk pricing and personalized service.
          Our network in the USA and Canada allows us to source products efficiently
          and pass savings to you.
        </p>
      </div>

      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon benefit-image">
            <img src="/images/competitive-pricing.jpg" alt="Competitive Pricing">
          </div>
          <h3>Competitive Pricing</h3>
          <p>Better prices for larger quantities. The more you order, the more you save.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon benefit-image">
            <img src="/images/dedicated-support.jpg" alt="Dedicated Support">
          </div>
          <h3>Dedicated Support</h3>
          <p>Personal account manager to handle your orders and answer questions.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon benefit-image">
            <img src="/images/custom-orders.jpg" alt="Custom Orders">
          </div>
          <h3>Custom Orders</h3>
          <p>We can source specific products based on your requirements.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon benefit-image">
            <img src="/images/priority-processing.jpg" alt="Priority Processing">
          </div>
          <h3>Priority Processing</h3>
          <p>We value your time so we make sure your order is carefully handled.</p>
        </div>
      </div>

      <div class="process-section">
        <h2>How Bulk Orders Work</h2>
        <div class="process-list">
          <div class="process-item">
            <div class="process-icon">1️⃣</div>
            <div>
              <h4>Contact Us</h4>
              <p>Reach out with your product requirements, quantities, and timeline.</p>
            </div>
          </div>
          <div class="process-item">
            <div class="process-icon">2️⃣</div>
            <div>
              <h4>Quote & Planning</h4>
              <p>We provide a detailed quote including all costs, shipping time, and payment terms.</p>
            </div>
          </div>
          <div class="process-item">
            <div class="process-icon">3️⃣</div>
            <div>
              <h4>Order Confirmation</h4>
              <p>Once approved, we confirm your order and begin sourcing products.</p>
            </div>
          </div>
          <div class="process-item">
            <div class="process-icon">4️⃣</div>
            <div>
              <h4>Sourcing & Import</h4>
              <p>Our team in the USA/Canada purchases and ships your order. We handle all import procedures.</p>
            </div>
          </div>
          <div class="process-item">
            <div class="process-icon">5️⃣</div>
            <div>
              <h4>Delivery</h4>
              <p>Your order arrives and is ready for pickup or delivery as arranged.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="pricing-section" style="background: var(--bg-light); padding: 3rem; border-radius: 10px; margin: 3rem 0;">
        <h2 style="text-align: center; margin-bottom: 2rem;">Pricing Structure</h2>
        <div class="pricing-info">
          <p>
            Bulk order pricing is customized based on:
          </p>
          <ul class="pricing-list">
            <li>Order quantity and volume</li>
            <li>Product categories selected</li>
            <li>Shipping method and timeline</li>
            <li>Payment terms</li>
            <li>Frequency of orders (recurring orders get better rates)</li>
          </ul>
          <p style="margin-top: 1.5rem;">
            <strong>Contact us for a personalized quote</strong> - we'll work with you to find 
            the best pricing structure for your needs.
          </p>
        </div>
      </div>

      <div class="contact-form-section">
        <h2>Request a Bulk Order Quote</h2>
        <p class="form-intro">Fill out the form below or contact us directly via WhatsApp for faster response.</p>

        <div class="quick-whatsapp">
          <a href="https://wa.me/237679457181?text=Hi%2C%20I%27m%20interested%20in%20placing%20a%20bulk%20order.%20Can%20you%20help%20me%3F"
             target="_blank"
             rel="noopener noreferrer"
             class="btn whatsapp-btn">
            Chat on WhatsApp for Bulk Orders
          </a>
        </div>

        <form class="bulk-form" id="bulk-form" action={web3formsEndpoint} method="POST">
          <input type="hidden" name="access_key" value={web3formsKey}>
          <input type="hidden" name="subject" value="New Bulk Order Request - American Select">
          <input type="hidden" name="from_name" value="American Select Website">
          <div class="form-group">
            <label for="name">Your Name / Company Name *</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-group">
            <label for="email">Email Address <span style="font-weight:400; color:#888;">(optional)</span></label>
            <input type="email" id="email" name="email">
          </div>
          <div class="form-group">
            <label for="phone">Phone / WhatsApp Number *</label>
            <input type="tel" id="phone" name="phone" required placeholder="e.g. 679 457 181">
          </div>
          <div class="form-group">
            <label for="products">Products of Interest *</label>
            <textarea id="products" name="products" rows="4" required placeholder="List the products and approximate quantities you're interested in"></textarea>
          </div>
          <div class="form-group">
            <label for="timeline">Desired Timeline</label>
            <input type="text" id="timeline" name="timeline" placeholder="e.g., Within 2 months">
          </div>
          <div class="form-group">
            <label for="message">Additional Information</label>
            <textarea id="message" name="message" rows="4" placeholder="Any specific requirements or questions"></textarea>
          </div>
          <input type="text" name="_gotcha" style="display:none">
          <button type="submit" class="btn" id="bulk-submit-btn">Request Quote</button>
        </form>
        <div id="bulk-success" style="display:none; text-align:center; padding: 2rem 1rem;">
          <h3 style="color: #28a745; margin-bottom: 1rem;">Request Sent!</h3>
          <p>Thank you for your bulk order inquiry! We will review your request and get back to you within 24-48 hours. For faster response, you can call or reach us on WhatsApp at <a href="https://wa.me/237679457181">679 457 181</a> or <a href="https://wa.me/237686271567">686 271 567</a>.</p>
          <button class="btn" id="bulk-another-btn" style="margin-top: 1.5rem;">Send Another Request</button>
        </div>
        <p class="form-note" id="bulk-form-note">We typically respond to bulk inquiries within 24-48 hours.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const fr = navigator.language.startsWith('fr');

  const t = {
    sending:      fr ? 'Envoi en cours...'        : 'Sending...',
    submit:       fr ? 'Demander un devis'         : 'Request Quote',
    successTitle: fr ? 'Demande envoyée !'         : 'Request Sent!',
    successText:  fr
      ? `Merci pour votre demande ! Nous l'examinerons et vous répondrons dans les 24 à 48 heures. Pour une réponse plus rapide, appelez-nous ou contactez-nous sur WhatsApp au <a href="https://wa.me/237679457181">679 457 181</a> ou <a href="https://wa.me/237686271567">686 271 567</a>.`
      : `Thank you for your bulk order inquiry! We will review your request and get back to you within 24-48 hours. For faster response, you can call or reach us on WhatsApp at <a href="https://wa.me/237679457181">679 457 181</a> or <a href="https://wa.me/237686271567">686 271 567</a>.`,
    another:      fr ? 'Envoyer une autre demande' : 'Send Another Request',
    error:        fr ? 'Une erreur s\'est produite. Veuillez réessayer ou nous contacter sur WhatsApp.' : 'Something went wrong. Please try again or contact us on WhatsApp.',
  };

  const form = document.getElementById('bulk-form') as HTMLFormElement;
  const successMsg = document.getElementById('bulk-success');
  const formNote = document.getElementById('bulk-form-note');
  const submitBtn = document.getElementById('bulk-submit-btn') as HTMLButtonElement;
  const anotherBtn = document.getElementById('bulk-another-btn');

  anotherBtn?.addEventListener('click', () => {
    form.reset();
    successMsg.style.display = 'none';
    form.style.display = '';
    formNote.style.display = '';
    submitBtn.disabled = false;
    submitBtn.textContent = t.submit;
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = t.sending;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      });

      if (res.ok) {
        successMsg.querySelector('h3').textContent = t.successTitle;
        successMsg.querySelector('p').innerHTML = t.successText;
        anotherBtn.textContent = t.another;
        form.style.display = 'none';
        formNote.style.display = 'none';
        successMsg.style.display = 'block';
      } else {
        alert(t.error);
        submitBtn.disabled = false;
        submitBtn.textContent = t.submit;
      }
    } catch {
      alert(t.error);
      submitBtn.disabled = false;
      submitBtn.textContent = t.submit;
    }
  });
</script>

