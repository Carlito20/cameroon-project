---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank You - American Select">
  <!-- Generic thank-you (contact form) — hidden if order confirmation is detected -->
  <section class="thank-you-section" id="generic-section">
    <div class="container">
      <div class="thank-you-content">
        <div class="success-icon">✓</div>
        <h1>Thank You!</h1>
        <p class="lead">Your message has been sent successfully.</p>
        <p>We've received your inquiry and will get back to you within 24 hours.</p>
        <div class="action-buttons">
          <a href="/" class="btn btn-primary">Back to Home</a>
          <a href="https://wa.me/237670358551" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Chat on WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Order confirmation — shown when coming from cart confirm flow -->
  <section class="order-confirm-section" id="order-section" style="display:none;">
    <div class="oc-container">

      <div class="oc-header">
        <div class="oc-check">✅</div>
        <h1>Order Confirmed!</h1>
        <p class="oc-ref" id="oc-ref" style="display:none;"></p>
        <p class="oc-sub">Your confirmation has been sent to us on WhatsApp. We'll be in touch shortly.</p>
      </div>

      <!-- Order summary (filled by JS) -->
      <div class="oc-card" id="oc-summary">
        <div class="oc-card-title">📋 Your Order</div>
        <div id="oc-items"></div>
        <div class="oc-total-row">
          <span>Total</span>
          <span id="oc-total" class="oc-total-amt"></span>
        </div>
      </div>

      <!-- Payment instructions (filled by JS) -->
      <div class="oc-card" id="oc-payment">
        <div class="oc-card-title">💳 Payment Instructions</div>
        <div id="oc-pay-instructions"></div>
      </div>

      <!-- What's next -->
      <div class="oc-card">
        <div class="oc-card-title">🚀 What Happens Next</div>
        <ol class="oc-steps">
          <li>We review your order and confirm availability on WhatsApp</li>
          <li>You complete payment using the method above</li>
          <li>We arrange delivery or pickup with you directly</li>
          <li>Enjoy your items! 🎉</li>
        </ol>
      </div>

      <div class="oc-actions">
        <a href="/shop/" class="btn btn-outline-dark">Continue Shopping</a>
        <a href="https://wa.me/237670358551" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp">
          💬 Chat With Us
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  // Payment details — update these numbers as needed
  const PAYMENT_DETAILS = {
    'MTN MoMo': {
      number: '670358551',
      name: 'American Select',
      instructions: 'Send payment via MTN Mobile Money to the number above. Use your name as the reference.'
    },
    'Orange Money': {
      number: '690000000', // ← update this with your Orange Money number
      name: 'American Select',
      instructions: 'Send payment via Orange Money to the number above. Use your name as the reference.'
    },
    'Cash': {
      instructions: 'Pay in cash on delivery or at pickup. Our team will confirm the arrangement with you on WhatsApp.'
    },
    'Not sure yet': {
      instructions: 'No problem! We\'ll discuss payment options with you when we confirm your order on WhatsApp.'
    }
  };

  function formatPrice(n) {
    return Number(n).toLocaleString('en-US');
  }

  function buildPaymentInstructions(method) {
    const info = PAYMENT_DETAILS[method];
    if (!info) return `<p>We'll confirm payment details with you on WhatsApp.</p>`;

    let html = '';
    if (info.number) {
      html += `<div class="pay-number-box">
        <div class="pay-method-name">${method}</div>
        <div class="pay-number">${info.number}</div>
        <div class="pay-account-name">${info.name}</div>
      </div>`;
    }
    html += `<p class="pay-note">${info.instructions}</p>`;
    return html;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    if (params.get('order') !== 'confirmed') return;

    let order;
    try {
      const raw = localStorage.getItem('confirmedOrder');
      if (!raw) return;
      order = JSON.parse(raw);
      localStorage.removeItem('confirmedOrder');
    } catch { return; }

    // Switch UI
    document.getElementById('generic-section').style.display = 'none';
    document.getElementById('order-section').style.display = 'block';

    // Show order ref if available
    if (order.orderRef) {
      const refEl = document.getElementById('oc-ref');
      refEl.textContent = 'Order Ref: ' + order.orderRef;
      refEl.style.display = 'block';
    }

    // Fill items
    let itemsHtml = '';
    order.items.forEach(item => {
      const line = (item.price || 0) * (item.quantity || 1);
      itemsHtml += `<div class="oc-item">
        <div class="oc-item-name">${item.name}</div>
        <div class="oc-item-meta">
          <span class="oc-item-qty">×${item.quantity || 1}</span>
          ${item.price ? `<span class="oc-item-price">${formatPrice(item.price)} FCFA each</span>` : ''}
          ${item.price ? `<span class="oc-item-line">${formatPrice(line)} FCFA</span>` : ''}
        </div>
      </div>`;
    });
    document.getElementById('oc-items').innerHTML = itemsHtml;
    document.getElementById('oc-total').textContent = formatPrice(order.total) + ' FCFA';

    // Fill payment instructions
    document.getElementById('oc-pay-instructions').innerHTML =
      buildPaymentInstructions(order.paymentMethod);
  });
</script>

<style>
  /* ── Generic section ── */
  .thank-you-section {
    min-height: 70vh; display: flex; align-items: center;
    justify-content: center; padding: 4rem 1rem;
    background: linear-gradient(135deg, #f5f7fa 0%, #e4e9f2 100%);
  }
  .thank-you-content {
    text-align: center; max-width: 600px; background: white;
    padding: 3rem; border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.1);
  }
  .success-icon {
    width: 80px; height: 80px; background: #27ae60; color: white;
    font-size: 2.5rem; font-weight: bold; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.5rem;
  }
  .thank-you-content h1 { color: #2c3e50; margin-bottom: 1rem; font-size: 2.5rem; }
  .lead { font-size: 1.25rem; color: #27ae60; font-weight: 600; margin-bottom: 0.5rem; }
  p { color: #666; margin-bottom: 0.5rem; }

  /* ── Order confirmation section ── */
  .order-confirm-section {
    min-height: 100vh; padding: 2rem 1rem 4rem;
    background: linear-gradient(135deg, #f0fff4 0%, #e8f5e9 100%);
  }
  .oc-container { max-width: 580px; margin: 0 auto; }

  .oc-header { text-align: center; padding: 2rem 0 1.5rem; }
  .oc-check { font-size: 56px; margin-bottom: 12px; }
  .oc-header h1 { color: #1a5c2e; font-size: 2rem; margin-bottom: 8px; }
  .oc-ref { font-size: 13px; font-weight: 700; color: #25a244; letter-spacing: 1px; margin: 6px 0 4px; }
  .oc-sub { color: #4a7c5a; font-size: 1rem; max-width: 380px; margin: 0 auto; }

  .oc-card {
    background: white; border-radius: 16px; padding: 20px 22px;
    margin-bottom: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  }
  .oc-card-title {
    font-size: 14px; font-weight: 700; color: #333;
    text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 14px;
  }

  /* Items */
  .oc-item { padding: 10px 0; border-bottom: 1px solid #f0f0f0; }
  .oc-item:last-child { border-bottom: none; }
  .oc-item-name { font-size: 14px; color: #222; font-weight: 500; line-height: 1.4; margin-bottom: 4px; }
  .oc-item-meta { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  .oc-item-qty { font-size: 12px; background: #f0f0f0; color: #555; padding: 2px 8px; border-radius: 20px; }
  .oc-item-price { font-size: 12px; color: #888; }
  .oc-item-line { font-size: 13px; font-weight: 700; color: #25a244; margin-left: auto; }
  .oc-total-row {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 14px; margin-top: 4px; border-top: 2px solid #f0f0f0;
    font-weight: 700; font-size: 15px; color: #333;
  }
  .oc-total-amt { font-size: 20px; color: #25a244; }

  /* Payment */
  .pay-number-box {
    background: #f8fff9; border: 1px solid #c3e6cb;
    border-radius: 10px; padding: 14px 16px; margin-bottom: 12px; text-align: center;
  }
  .pay-method-name { font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .pay-number { font-size: 26px; font-weight: 800; color: #1a5c2e; letter-spacing: 2px; margin-bottom: 4px; }
  .pay-account-name { font-size: 13px; color: #555; font-weight: 600; }
  .pay-note { font-size: 13px; color: #666; line-height: 1.5; margin: 0; }

  /* Steps */
  .oc-steps { padding-left: 20px; margin: 0; }
  .oc-steps li { padding: 6px 0; color: #555; font-size: 14px; line-height: 1.5; }

  /* Buttons */
  .oc-actions { display: flex; gap: 12px; margin-top: 8px; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 12px 24px; font-size: 15px; font-weight: 700;
    text-decoration: none; border-radius: 50px;
    min-height: 48px; touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    -webkit-user-select: none; user-select: none;
    transition: all 0.2s; flex: 1; text-align: center;
  }
  .btn-outline-dark { background: white; color: #333; border: 2px solid #ddd; }
  .btn-outline-dark:hover { border-color: #aaa; color: #000; }
  .btn-whatsapp { background: #25d366; color: white; border: none; }
  .btn-whatsapp:hover { background: #1ebe5d; }
  .btn-primary { background: #111; color: white; border: none; }
  .btn-primary:hover { background: #f0a500; color: #111; }
  .btn-outline { background: white; color: #25d366; border: 2px solid #25d366; }
  .btn-outline:hover { background: #25d366; color: white; }

  .action-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem; }

  @media (max-width: 480px) {
    .oc-header h1 { font-size: 1.7rem; }
    .oc-card { padding: 16px; }
    .btn { font-size: 14px; padding: 11px 16px; }
  }
</style>
